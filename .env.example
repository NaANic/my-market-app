# Initial balance for payment-service in kopecks (1000.00 RUB = 100000)
PAYMENT_INITIAL_BALANCE=1000000

# Keycloak client_credentials configuration (used by market-app to call payment-service)
# After running `docker compose up keycloak` and following docs/keycloak-setup.md,
# copy the generated client secret here.
KEYCLOAK_CLIENT_ID=market-app
KEYCLOAK_CLIENT_SECRET=please-override-after-keycloak-setup
